# Railway managed Postgres variables are often injected as DATABASE_URL.
# Keep sslmode=require for hosted Postgres.
PORT=4000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require"
FRONTEND_ORIGIN="*"
HEADLINE_WEBID_BASE="https://headline-production.up.railway.app"
HEADLINE_API_BASE="https://headline-production.up.railway.app"
HEADLINE_PORTAL_BASE="https://portal.headline-agentur.com"
