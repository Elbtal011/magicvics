# Railway managed Postgres variables are often injected as DATABASE_URL.
# Keep sslmode=require for hosted Postgres.
PORT=4000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require"
FRONTEND_ORIGIN="https://onvver.com,https://www.onvver.com,https://portal.onvver.com"
HEADLINE_WEBID_BASE="https://onvver.com"
HEADLINE_API_BASE="https://onvver.com"
HEADLINE_PORTAL_BASE="https://portal.onvver.com"

# Outgoing automated email
EMAIL_PROVIDER="smtp"
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL="info@onvver.com"
SMTP_FROM_NAME="ONV Verbund"
