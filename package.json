{
  "name": "magicvics-mirror",
  "private": true,
  "version": "1.0.0",
  "description": "Static mirror of magicvics admin frontend",
  "scripts": {
    "start": "node server.mjs",
    "start:frontend": "node server.mjs",
    "backend:install": "npm --prefix backend install",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start",
    "backend:migrate": "npm --prefix backend run prisma:migrate",
    "backend:deploy": "npm --prefix backend run prisma:deploy",
    "backend:seed": "npm --prefix backend run prisma:seed",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  }
}
